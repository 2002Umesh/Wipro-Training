pipeline {
    agent any
 
    tools {
        maven 'Maven3'
    }
 
    stages {
 
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/2002Umesh/Wipro-Training/tree/main/PHPTravels'
            }
        }
 
        stage('Build') {
            steps {
                dir('PHPTravels') {
                    bat 'mvn clean'
                }
            }
        }
 
        stage('Compile') {
            steps {
                dir('PHPTravels') {
                    bat 'mvn compile'
                }
            }
        }
 
        stage('Test') {
            steps {
                dir('PHPTravels') {
                    bat 'mvn test'
                }
            }
        }
 
        stage('Package') {
            steps {
                dir('PHPTravels') {
                    bat 'mvn package'
                }
            }
        }
    }
 
    post {
        success {
            echo 'Build Successful'
        }
 
        failure {
            echo 'Build Failed'
        }
    }
}